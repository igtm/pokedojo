---
import { getCollection, render } from 'astro:content'
import { glossaryTerms } from '../../lib/glossary'

interface SearchRecord {
  title: string
  description: string
  heading: string
  url: string
  text: string
  excerpt: string
}

const docs = await getCollection('docs', ({ data }) => !data.draft && data.pagefind !== false)
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`

function toUrl(id: string): string {
  const cleanId = id.replace(/\/index$/, '')
  if (cleanId === 'index') return baseUrl
  return `${baseUrl}${cleanId}/`
}

function toText(markdown: string): string {
  return markdown
    .replace(/^import .+$/gm, ' ')
    .replace(/<QuizBlock[\s\S]*?\/>/g, ' ')
    .replace(/<MermaidDiagram[\s\S]*?<\/MermaidDiagram>/g, ' ')
    .replace(/<(DamageFactorsDiagram|SpeedOrderDiagram)[\s\S]*?\/>/g, ' ')
    .replace(/\{glossaryTerms\.map[\s\S]*?\)\)\}/g, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/[{}[\]()`*_>#:-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
}

function toHeadingText(value: string): string {
  return value
    .replace(/<[^>]+>/g, ' ')
    .replace(/[{}[\]()`*_>#]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
}

function toSections(
  markdown: string,
  pageUrl: string,
  title: string,
  description: string,
  headings: { depth: number; slug: string; text: string }[],
): SearchRecord[] {
  const sections: SearchRecord[] = [
    {
      title,
      description,
      heading: '概要',
      url: pageUrl,
      text: `${title} ${description}`,
      excerpt: `${title} ${description}`,
    },
  ]
  const renderedHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3)
  const headingPattern = /^(#{2,3})\s+(.+)$/gm
  const markdownHeadings = [...markdown.matchAll(headingPattern)]

  for (let index = 0; index < markdownHeadings.length; index += 1) {
    const match = markdownHeadings[index]
    const renderedHeading = renderedHeadings[index]
    const heading = renderedHeading?.text ?? toHeadingText(match[2] ?? '')
    const start = (match.index ?? 0) + match[0].length
    const end =
      index + 1 < markdownHeadings.length ? (markdownHeadings[index + 1].index ?? markdown.length) : markdown.length
    const text = toText(markdown.slice(start, end))

    if (!heading || !text) continue

    const url = renderedHeading?.slug ? `${pageUrl}#${encodeURIComponent(renderedHeading.slug)}` : pageUrl
    sections.push({
      title,
      description,
      heading,
      url,
      text: `${title} ${description} ${heading} ${text}`,
      excerpt: text,
    })
  }

  return sections
}

const searchData: SearchRecord[] = (
  await Promise.all(
    docs.map(async (entry) => {
      const body = 'body' in entry && typeof entry.body === 'string' ? entry.body : ''
      const isGlossary = entry.id === 'glossary' || entry.id === 'glossary/index'
      const pageUrl = toUrl(entry.id)
      const { headings } = await render(entry)
      const pageSections = isGlossary
        ? []
        : toSections(body, pageUrl, entry.data.title, entry.data.description ?? '', headings)
      const glossarySections = isGlossary
        ? glossaryTerms.map((term) => {
            const text = `${term.term} ${term.category} ${term.description} ${term.example}`
            return {
              title: entry.data.title,
              description: entry.data.description ?? '',
              heading: term.term,
              url: `${pageUrl}#${encodeURIComponent(term.term)}`,
              text,
              excerpt: text,
            }
          })
        : []

      return [...pageSections, ...glossarySections]
    }),
  )
).flat()

const label = Astro.locals.t('search.label')
const cancelLabel = Astro.locals.t('search.cancelLabel')
const ctrlLabel = Astro.locals.t('search.ctrlKey')
---

<dojo-search class={Astro.props.class}>
  <button data-open-modal type="button" aria-label={label} aria-keyshortcuts="Control+K">
    <span aria-hidden="true">⌕</span>
    <span class="sl-hidden md:sl-block">{label}</span>
    <kbd class="sl-hidden md:sl-flex"><kbd>{ctrlLabel}</kbd><kbd>K</kbd></kbd>
  </button>

  <dialog aria-label={label}>
    <div class="dojo-search__frame">
      <div class="dojo-search__bar">
        <input
          data-search-input
          type="search"
          aria-label="検索キーワード"
          placeholder="用語、タイプ、構築を検索"
          autocomplete="off"
        />
        <button data-close-modal type="button">{cancelLabel}</button>
      </div>
      <p data-search-status class="dojo-search__status">キーワードを入力してください。</p>
      <div data-search-results class="dojo-search__results"></div>
    </div>
  </dialog>
</dojo-search>

<script is:inline define:vars={{ searchData }}>
  class DojoSearch extends HTMLElement {
    connectedCallback() {
      const openButton = this.querySelector('[data-open-modal]')
      const closeButton = this.querySelector('[data-close-modal]')
      const dialog = this.querySelector('dialog')
      const frame = this.querySelector('.dojo-search__frame')
      const input = this.querySelector('[data-search-input]')
      const status = this.querySelector('[data-search-status]')
      const results = this.querySelector('[data-search-results]')

      if (!openButton || !closeButton || !dialog || !frame || !input || !status || !results) return

      const openModal = (event) => {
        dialog.showModal()
        document.body.toggleAttribute('data-search-modal-open', true)
        input.focus()
        event?.stopPropagation()
      }

      const closeModal = () => {
        dialog.close()
        document.body.toggleAttribute('data-search-modal-open', false)
      }

      const render = () => {
        const query = input.value.trim()
        results.innerHTML = ''

        if (!query) {
          status.textContent = 'キーワードを入力してください。'
          return
        }

        const terms = query
          .toLowerCase()
          .split(/\s+/)
          .filter(Boolean)
        const matches = searchData
          .map((item) => {
            const haystack = item.text.toLowerCase()
            const score = terms.reduce((total, term) => total + (haystack.includes(term) ? 1 : 0), 0)
            const excerpt = item.excerpt || item.text
            const lowerExcerpt = excerpt.toLowerCase()
            const snippetSource = terms.some((term) => lowerExcerpt.includes(term)) ? excerpt : item.text
            return { item, score, snippet: createSnippet(snippetSource, terms) }
          })
          .filter((entry) => entry.score > 0)
          .sort(
            (a, b) =>
              b.score - a.score ||
              a.item.title.localeCompare(b.item.title, 'ja') ||
              a.item.heading.localeCompare(b.item.heading, 'ja'),
          )
          .slice(0, 8)

        status.textContent = matches.length ? `${matches.length}件の候補` : '一致するページがありません。'

        for (const { item, snippet } of matches) {
          const link = document.createElement('a')
          link.className = 'dojo-search__result'
          link.href = item.url
          link.innerHTML = `
            <strong>${escapeHtml(item.title)}</strong>
            <span>${escapeHtml(item.heading)}</span>
            <p>${snippet}</p>
          `
          results.append(link)
        }
      }

      const onWindowClick = (event) => {
        if (dialog.open && document.body.contains(event.target) && !frame.contains(event.target)) {
          closeModal()
        }
      }

      openButton.addEventListener('click', openModal)
      closeButton.addEventListener('click', closeModal)
      input.addEventListener('input', render)
      results.addEventListener('click', (event) => {
        const link = event.target.closest('a')
        if (!link) return

        const target = new URL(link.href)
        closeModal()

        if (target.origin === location.origin && target.pathname === location.pathname && target.hash) {
          event.preventDefault()
          history.pushState(null, '', target)
          const targetElement = document.getElementById(decodeURIComponent(target.hash.slice(1)))
          targetElement?.closest('details')?.setAttribute('open', '')
          targetElement?.scrollIntoView()
        }
      })
      window.addEventListener('click', onWindowClick)
      window.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
          dialog.open ? closeModal() : openModal(event)
          event.preventDefault()
        }
        if (event.key === 'Escape' && dialog.open) closeModal()
      })
    }
  }

  function escapeHtml(value) {
    return value.replace(/[&<>"']/g, (char) => {
      const entities = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }
      return entities[char]
    })
  }

  function escapeRegExp(value) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
  }

  function createSnippet(value, terms) {
    const source = value.replace(/\s+/g, ' ').trim()
    const lowerSource = source.toLowerCase()
    const hit = terms
      .map((term) => ({ term, index: lowerSource.indexOf(term) }))
      .filter((entry) => entry.index >= 0)
      .sort((a, b) => a.index - b.index)[0]

    if (!hit) return escapeHtml(source.slice(0, 140))

    const start = Math.max(0, hit.index - 54)
    const end = Math.min(source.length, hit.index + hit.term.length + 86)
    const snippet = `${start > 0 ? '…' : ''}${source.slice(start, end)}${end < source.length ? '…' : ''}`
    const escapedTerms = terms.map(escapeRegExp).filter(Boolean)
    if (!escapedTerms.length) return escapeHtml(snippet)

    const pattern = new RegExp(`(${escapedTerms.join('|')})`, 'gi')
    return escapeHtml(snippet).replace(pattern, '<mark>$1</mark>')
  }

  customElements.define('dojo-search', DojoSearch)
</script>
