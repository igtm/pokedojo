---
const layers = [
  {
    label: '1',
    title: '優先度を比べる',
    detail: '高い優先度の技は、低い優先度の技より先に動く。',
  },
  {
    label: '2',
    title: '順番ルールを見る',
    detail: '通常時は速い順、トリックルーム中は遅い順。同じ優先度の中だけで変わる。',
  },
  {
    label: '3',
    title: '現在の素早さを比べる',
    detail: 'まひ、ランク、持ち物、天候、特性などで変わった後の速さを見る。',
  },
]
---

<figure class="dojo-diagram dojo-speed-diagram">
  <figcaption>
    <strong>行動順を見る順番</strong>
    <span>素早さで勝てるのは、基本的に同じ優先度の中だけ。</span>
  </figcaption>
  <div class="dojo-speed-diagram__layers" aria-label="行動順を決める要素">
    {
      layers.map((layer) => (
        <div class="dojo-speed-diagram__layer">
          <span>{layer.label}</span>
          <strong>{layer.title}</strong>
          <p>{layer.detail}</p>
        </div>
      ))
    }
  </div>
</figure>
